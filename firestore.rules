rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(session) {
      return isSignedIn() && session.data.customerUid == request.auth.uid;
    }

    match /chat_sessions/{sessionId} {
      allow create: if isSignedIn()
        && request.resource.data.customerUid == request.auth.uid
        && request.resource.data.customerName is string;

      allow read: if isSignedIn();

      allow update: if isSignedIn() && (
        resource.data.customerUid == request.auth.uid ||
        true
      );

      match /messages/{messageId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && (
          get(/databases/$(database)/documents/chat_sessions/$(sessionId)).data.customerUid == request.auth.uid ||
          true
        );
      }
    }
  }
}
